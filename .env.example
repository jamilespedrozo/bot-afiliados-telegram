# ============================================================
# BOT AFILIADOS - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Token do seu bot Telegram (obtenha no @BotFather)
TELEGRAM_BOT_TOKEN=SEU_TOKEN_AQUI

# Chave da API Google Gemini (para gerar descrições)
# Obtenha grátis em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=SUA_CHAVE_GEMINI_AQUI

# (Opcional) IDs dos usuários autorizados a usar o bot
# Separe por vírgula. Deixe vazio para permitir todos.
# Exemplo: ALLOWED_USERS=123456789,987654321
ALLOWED_USERS=
