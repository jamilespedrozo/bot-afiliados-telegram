# ============================================================
# BOT AFILIADOS - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Token do seu bot Telegram (obtenha no @BotFather)
TELEGRAM_BOT_TOKEN=SEU_TOKEN_AQUI

# Chave da API Google Gemini (para gerar descrições com IA)
# Obtenha grátis em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=SUA_CHAVE_GEMINI_AQUI

# ID do administrador do bot (seu ID do Telegram)
# Envie /start no bot para descobrir seu ID
ADMIN_ID=0

# ============================================================
# BANCO DE DADOS (Railway injeta automaticamente)
# ============================================================
# DATABASE_URL=postgresql://user:password@host:port/dbname

# ============================================================
# WEBHOOK KIWIFY (proteção do endpoint)
# ============================================================
WEBHOOK_SECRET=minhachave123

# ============================================================
# PLANOS DE ACESSO (dias)
# ============================================================
PLANO_MENSAL_DIAS=30
PLANO_TRIMESTRAL_DIAS=90
PLANO_ANUAL_DIAS=365
# Vitalício = 0 dias (sem expiração) - configurado automaticamente

# ============================================================
# MODELO FREEMIUM
# ============================================================
# Número de vídeos grátis por dia (reset diário à meia-noite)
FREE_USAGE_LIMIT=3

# Link da página de vendas (exibido quando o limite é atingido)
LINK_COMPRA=https://charm-craft-sell.lovable.app
